{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MirroXD",
  "version": "0.1.0",
  "identifier": "com.mirroxd.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MirroXD",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "toolbar",
        "title": "Toolbar",
        "url": "/",
        "width": 260,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/adb"
    ]
  }
}